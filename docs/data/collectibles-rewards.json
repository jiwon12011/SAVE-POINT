{
  "version": "1.0",
  "meta": {
    "purpose": "보상 경제 + 도감 마스터 데이터. 별사탕(재화) 규칙, 칭호·회복아이템 도감, 연속 세이브 마일스톤, unlock_rule 스키마.",
    "source": "docs/기획.md §5(보상 경제) · §5-2(unlock_rule 스키마)",
    "philosophy": "세이브=완료 아님. 세이브 자체 보상은 퀘스트 완료와 독립. 컨디션 나쁠수록 작은 행동 가치를 올림(modeParams.rewardMultiplier).",
    "evaluation": "unlock 평가는 서버 단일 주체(트리거/RPC, 멱등 INSERT). 동기화 시 전체 룰 재평가 1회. (기획 §5-2)"
  },
  "unlockRuleSchema": {
    "_doc": "도감 항목의 unlock_rule jsonb 형식. type 별 필드.",
    "types": {
      "save_count":       "{ type:'save_count', op:'>=', value:N }  — 누적 세이브 수",
      "streak":           "{ type:'streak', op:'>=', value:N }  — 현재/최장 연속 세이브",
      "streak_mode":      "{ type:'streak_mode', mode:'survival', op:'>=', value:N }  — 특정 모드 연속 세이브",
      "tag_count":        "{ type:'tag_count', tag:'caffeine_overload', op:'>=', value:N }  — 특정 상태이상 누적 선택",
      "mode_first":       "{ type:'mode_first', mode:'challenge' }  — 특정 모드 첫 도달",
      "zero_quest_save":  "{ type:'zero_quest_save', op:'>=', value:N }  — 퀘스트 0완료 세이브(망한 날 세이브)",
      "comeback":         "{ type:'comeback', op:'>=', value:N }  — 컴백(gap_days≥7 후 복귀) 횟수",
      "npc_dialogue":     "{ type:'npc_dialogue', npc:'healer', op:'>=', value:N }  — 특정 NPC 대사 수신 수",
      "recovery_use":     "{ type:'recovery_use', item:'tea', op:'>=', value:N }  — 특정 회복 아이템 사용 수"
    },
    "op": "현재 '>=' 만 사용. 확장 시 '==','>' 등 추가 가능"
  },
  "stardust": {
    "_doc": "별사탕 = 앱 재화. 적립은 완료와 독립(세이브 자체 +10).",
    "earn": {
      "questComplete": { "base": 5, "multiplierFrom": "fallback-quests.json modeParams.rewardMultiplier", "note": "완료당 base×배율" },
      "save":          { "amount": 10, "note": "세이브 1회 고정. 퀘스트 0완료여도 지급" },
      "streakMilestone": { "from": "milestones 배열" }
    },
    "spend": {
      "npcReroll":          { "cost": 5,   "note": "NPC 대사 1회 더 듣기(리롤). 일일 호출 상한과 연결" },
      "instantCodexUnlock": { "cost": 30,  "note": "해금 조건 미달 도감 항목 즉시 해금(일부만 허용)" },
      "themeUnlock":        { "cost": 100, "note": "상태창 테마" },
      "npcSkin":            { "cost": 150, "note": "NPC 스킨" }
    }
  },
  "milestones": [
    { "streak": 7,   "bonusStardust": 50,  "titleId": "week_survivor" },
    { "streak": 30,  "bonusStardust": 200, "titleId": "month_survivor" },
    { "streak": 100, "bonusStardust": 500, "titleId": "hundred_days" }
  ],
  "titles": [
    { "id": "first_save",       "name": "첫 세이브",            "desc": "처음으로 오늘을 저장했어요.",                 "unlock_rule": { "type": "save_count", "op": ">=", "value": 1 } },
    { "id": "never_give_up",    "name": "포기하지 않은 자",      "desc": "아무것도 못 한 날에도 켰으니까.",             "unlock_rule": { "type": "zero_quest_save", "op": ">=", "value": 1 } },
    { "id": "survivor3",        "name": "버티는 자",            "desc": "3일 연속 생존 모드에서 세이브했어요.",        "unlock_rule": { "type": "streak_mode", "mode": "survival", "op": ">=", "value": 3 } },
    { "id": "comeback_hero",    "name": "돌아온 모험가",        "desc": "오래 비웠다가 다시 문을 열었어요.",           "unlock_rule": { "type": "comeback", "op": ">=", "value": 1 } },
    { "id": "challenger",       "name": "정면돌파자",          "desc": "처음으로 도전 모드에 도달했어요.",            "unlock_rule": { "type": "mode_first", "mode": "challenge" } },
    { "id": "deadline_survivor","name": "마감 직전 생존자",      "desc": "마감 공포를 세 번 이겨냈어요.",               "unlock_rule": { "type": "tag_count", "tag": "deadline_fear", "op": ">=", "value": 3 } },
    { "id": "caffeine_mage",    "name": "카페인 마법사",        "desc": "각성 물약에 다섯 번 의존했어요.",             "unlock_rule": { "type": "tag_count", "tag": "caffeine_overload", "op": ">=", "value": 5 } },
    { "id": "bed_ally",         "name": "침대와 동맹한 용사",    "desc": "수면 부족과 다섯 번 동행했어요.",             "unlock_rule": { "type": "tag_count", "tag": "sleep_deprivation", "op": ">=", "value": 5 } },
    { "id": "chased_traveler",  "name": "할 일에게 쫓기는 여행자","desc": "미루기와 다섯 번 마주쳤어요.",                "unlock_rule": { "type": "tag_count", "tag": "procrastination", "op": ">=", "value": 5 } },
    { "id": "lost_focus_student","name": "집중력 잃은 아카데미생","desc": "집중력 실종을 다섯 번 겪었어요.",             "unlock_rule": { "type": "tag_count", "tag": "focus_lost", "op": ">=", "value": 5 } },
    { "id": "week_survivor",    "name": "7일 생존자",          "desc": "7일 연속 세이브.",                           "unlock_rule": { "type": "streak", "op": ">=", "value": 7 } },
    { "id": "month_survivor",   "name": "한 달 생존자",         "desc": "30일 연속 세이브.",                          "unlock_rule": { "type": "streak", "op": ">=", "value": 30 } },
    { "id": "hundred_days",     "name": "백일의 모험가",        "desc": "100일 연속 세이브.",                         "unlock_rule": { "type": "streak", "op": ">=", "value": 100 } }
  ],
  "recoveryItems": [
    { "id": "tea",        "name": "따뜻한 차",   "effect": { "text": "시작 부담 -10", "stat": "start_resistance", "value": -10 }, "lore": "마음을 데우는 약초차.",        "unlock_rule": { "type": "default" } },
    { "id": "water",      "name": "물 한 잔",    "effect": { "text": "HP 회복 보조",  "stat": "hp", "value": 5 },             "lore": "가장 기본적인 회복.",          "unlock_rule": { "type": "default" } },
    { "id": "coffee",     "name": "커피",        "effect": { "text": "MP 임시 +(과다 시 카페인 과다)", "stat": "mp", "value": 10 }, "lore": "각성 물약. 과용 주의.",   "unlock_rule": { "type": "default" } },
    { "id": "walk",       "name": "산책",        "effect": { "text": "MP 회복",       "stat": "mp", "value": 10 },            "lore": "바깥 공기의 주문.",            "unlock_rule": { "type": "save_count", "op": ">=", "value": 3 } },
    { "id": "nap",        "name": "쪽잠",        "effect": { "text": "HP 회복",       "stat": "hp", "value": 15 },            "lore": "짧지만 강력한 회복 주문.",     "unlock_rule": { "type": "tag_count", "tag": "sleep_deprivation", "op": ">=", "value": 3 } },
    { "id": "meditation", "name": "명상",        "effect": { "text": "집중력 보조",   "stat": "focus", "value": 10 },         "lore": "마음을 가라앉히는 결계.",      "unlock_rule": { "type": "tag_count", "tag": "anxiety", "op": ">=", "value": 3 } },
    { "id": "potion",     "name": "회복 포션",   "effect": { "text": "전투불능 회피",  "stat": "revive", "value": 1 },         "lore": "쓰러지기 직전을 막는 비약.",   "unlock_rule": { "type": "mode_first", "mode": "survival" } }
  ],
  "ailmentCodex": {
    "_doc": "상태이상 도감. ailments.json 의 각 태그를 누적 N회 선택하면 해당 도감 해금. 항목은 ailments 배열에서 생성.",
    "source": "ailments.json",
    "unlockRulePerTag": { "type": "tag_count", "op": ">=", "value": 5 },
    "instantUnlockSpend": "instantCodexUnlock(30 별사탕)으로 조기 해금 허용"
  }
}
